# Example environment variables for backend
# Do NOT store real secrets here. Copy to `.env` and fill in values.
CLAUDE_API_KEY=
DATABASE_URL=sqlite:///./test.db  # SQLite for local dev; use Postgres in prod
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
MAX_TOKENS_PER_REQUEST=2000       # Max tokens allowed per LLM request
COST_LIMIT_PER_USER=1.00          # Max dollars per user (example)

# Comments:
# - CLAUDE_API_KEY: API key for Claude (keep secret). Do not commit.
# - DATABASE_URL: SQLAlchemy DB URL. For local testing use SQLite.
# - ENVIRONMENT: Controls settings and debugging.
# - LOG_LEVEL: Logging verbosity.
# - MAX_TOKENS_PER_REQUEST: Safety cap for LLM calls.
# - COST_LIMIT_PER_USER: Simple budget cap per user (USD).
